{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/platformai-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "JwtSettings": {
    "Issuer": "",
    "Audience": "",
    "SecretKey": "",
    "ExpirationMinutes": 60
  },
  "ConnectionStrings": {
    "MasterDatabase": "",
    "ApplicationDatabase": "",
    "BlobStorage": ""
  },
  "ML": {
    "ModelPath": "models/productionModel.zip"
  },
  "LLMSettings": {
    "Provider": "AzureOpenAI",
    "Endpoint": "",
    "ApiKey": "",
    "DeploymentName": "gpt-4o-mini",
    "ApiVersion": "2024-12-01-preview",
    "AgentId": "",
    "AgentName": "",
    "AgentInstructions": ""
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://industrialai.azurewebsites.net"
  ]
}
