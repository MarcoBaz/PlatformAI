{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/platformai-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "JwtSettings": {
    "Issuer": "your-issuer",
    "Audience": "your-audience",
    "SecretKey": "******",
    "ExpirationMinutes": 60
  },
  "ConnectionStrings": {
    "MasterDatabase": "*****",
    "ApplicationDatabase": "****"
  },
  "ML": {
    "ModelPath": "models/productionModel.zip"
  },
  "LLMSettings": {
    "Provider": "AzureOpenAI",
    "Endpoint": "****",
    "ApiKey": "******",
    "DeploymentName": "gpt-4o-mini",
    "ApiVersion": "2024-12-01-preview",
    "AgentId": "****",
    "AgentName": "Agent428",
    "AgentInstructions": "Sei un assistente AI intelligente e utile. Rispondi in modo chiaro, conciso e professionale. Se non sai qualcosa, ammettilo onestamente. Usa il markdown per formattare le risposte quando appropriato."
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://industrialai.azurewebsites.net"
  ]
}
